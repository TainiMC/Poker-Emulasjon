<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Arc?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="blackjack.AppController">

    <!-- MENU PANE -->
    <AnchorPane fx:id="anchorMenu" prefHeight="400.0" prefWidth="600.0">
        <children>
            <Button fx:id="NewGameButton" layoutX="263.0" layoutY="148.0" mnemonicParsing="false" onAction="#StartGame" text="New Game" />
            <Label layoutX="146.0" layoutY="14.0" text="Blackjack">
                <font>
                    <Font name="Berlin Sans FB" size="76.0" />
                </font>
            </Label>
            <Button fx:id="ContinueButton" layoutX="268.0" layoutY="188.0" mnemonicParsing="false" text="Continue" />
            <Button fx:id="settingsButton" layoutX="271.0" layoutY="234.0" mnemonicParsing="false" onAction="#Settings" text="Settings" />
            <Button fx:id="quitGameButton" layoutX="14.0" layoutY="361.0" mnemonicParsing="false" onAction="#quitGame" text="Quit Game" />
        </children>
    </AnchorPane>

    <!-- GAME PANE -->
    <AnchorPane fx:id="anchorGame" prefHeight="400.0" prefWidth="600.0" visible="false">
        <children>
            <Arc fill="#557d28fc" layoutX="296.0" layoutY="147.0" length="270.0" radiusX="290.0" radiusY="208.0" startAngle="135.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="3.0" type="CHORD" />
            <Label layoutX="255.0" text="Dealer">
                <font>
                    <Font size="29.0" />
                </font>
            </Label>
        </children>
    </AnchorPane>

    <!-- SETTINGS PANE -->
    <AnchorPane fx:id="anchorSettings" prefHeight="400.0" prefWidth="600.0" visible="false">
        <children>
            <Button layoutX="44.0" layoutY="333.0" mnemonicParsing="false" onAction="#Menu" text="Back" />
            <Label layoutX="218.0" layoutY="24.0" text="Settings">
                <font>
                    <Font size="46.0" />
                </font>
            </Label>
        </children>
    </AnchorPane>

</StackPane>
