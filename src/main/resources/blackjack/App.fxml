                <font>
                    <Font name="Berlin Sans FB" size="76.0" />
                </font>
            <effect>
               <Glow />
            </effect>
            </Label>
      </top>
      <center>
         <VBox maxHeight="-Infinity" maxWidth="200.0" prefHeight="295.0" prefWidth="200.0" spacing="25.0" BorderPane.alignment="CENTER">
            <children>
                  <Button fx:id="NewGameButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#StartNewGame" prefHeight="45.0" text="New Game" textAlignment="CENTER">
