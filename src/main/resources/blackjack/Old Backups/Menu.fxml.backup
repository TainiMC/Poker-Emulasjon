<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane fx:id="anchorMenu" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="blackjack.AppController">
   <children>
      <Button fx:id="NewGameButton" layoutX="263.0" layoutY="148.0" mnemonicParsing="false" onAction="#StartGame" text="New Game" />
      <Label layoutX="146.0" layoutY="14.0" text="Blackjack">
         <font>
            <Font name="Berlin Sans FB" size="76.0" />
         </font>
      </Label>
      <Button fx:id="ContinueButton" layoutX="268.0" layoutY="188.0" mnemonicParsing="false" text="Continue" />
      <Button fx:id="settingsButton" layoutX="271.0" layoutY="234.0" mnemonicParsing="false" onAction="#Settings" text="Settings" />
      <Button fx:id="quitGameButton" layoutX="14.0" layoutY="361.0" mnemonicParsing="false" onAction="#quitGame" text="Quit Game" />
   </children>
</AnchorPane>
